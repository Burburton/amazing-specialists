  "component_compatibility": {
    "contract_pack": {
      "1.0.0": {
        "compatible_package_versions": ["1.0.0"],
        "breaking_changes": [],
        "new_features": [
          "17 artifact schemas",
          "Registry with 17 contracts",
          "Validation utility"
        ]
      }
    },
    
    "template_pack": {
      "1.0.0": {
        "compatible_package_versions": ["1.0.0"],
        "profiles": {
          "minimal": {
            "file_count": 116,
            "skill_count": 21,
