{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/pack/reviewer/review-findings-report.schema.json",
  "title": "Review Findings Report Contract",
  "description": "Independent review report with severity-classified findings, governance alignment status, and actionable recommendations",
  "type": "object",
  "properties": {
    "report_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "review_target": {
      "type": "object",
      "properties": {
        "feature_id": { "type": "string" },
        "feature_name": { "type": "string" },
        "target_type": { "type": "string", "enum": ["feature", "task", "artifact", "milestone"] },
        "target_version": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["feature_id", "feature_name", "target_type", "target_version", "description"]
    },
    "reviewed_inputs": {
      "type": "object",
      "properties": {
        "upstream_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_type": { "type": "string" },
              "artifact_path": { "type": "string" },
              "artifact_version": { "type": "string" },
              "consumed_fully": { "type": "boolean" },
              "consumption_notes": { "type": ["string", "null"] }
            },
            "required": ["artifact_type", "artifact_path", "artifact_version", "consumed_fully"]
          }
        },
        "specs_reviewed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "spec_path": { "type": "string" },
              "spec_version": { "type": "string" }
            },
            "required": ["spec_path", "spec_version"]
          }
        },
        "canonical_documents_checked": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "document_type": { "type": "string" },
              "document_path": { "type": "string" },
              "check_performed": { "type": "boolean" }
            },
            "required": ["document_type", "document_path", "check_performed"]
          }
        }
      },
      "required": ["upstream_artifacts", "specs_reviewed", "canonical_documents_checked"]
    },
    "summary_judgment": {
      "type": "object",
      "properties": {
        "overall_assessment": { "type": "string", "enum": ["acceptable", "acceptable_with_concerns", "unacceptable", "needs_clarification"] },
        "key_strengths": { "type": "array", "items": { "type": "string" } },
        "critical_gaps": { "type": "array", "items": { "type": "string" } },
        "overall_risk_level": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "readiness_for_acceptance": { "type": "string", "enum": ["ready", "not_ready", "partially_ready"] }
      },
      "required": ["overall_assessment", "key_strengths", "critical_gaps", "overall_risk_level", "readiness_for_acceptance"]
    },
    "findings_by_severity": {
      "type": "object",
      "properties": {
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": "string" },
              "evidence": { "type": "string" },
              "impact": { "type": "string" },
              "recommended_remediation": { "type": "string" }
            },
            "required": ["finding_id", "title", "description", "location", "evidence", "impact", "recommended_remediation"]
          }
        },
        "major": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": "string" },
              "evidence": { "type": "string" },
              "impact": { "type": "string" },
              "recommended_remediation": { "type": "string" }
            },
            "required": ["finding_id", "title", "description", "location", "evidence", "impact", "recommended_remediation"]
          }
        },
        "minor": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": "string" },
              "evidence": { "type": "string" },
              "suggested_improvement": { "type": "string" }
            },
            "required": ["finding_id", "title", "description", "location", "evidence", "suggested_improvement"]
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "finding_id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": ["string", "null"] },
              "observation": { "type": "string" }
            },
            "required": ["finding_id", "title", "description", "observation"]
          }
        }
      },
      "required": ["blockers", "major", "minor", "notes"]
    },
    "evidence_references": {
      "type": "object",
      "properties": {
        "file_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "file_path": { "type": "string" },
              "line_range": { "type": ["string", "null"] },
              "context": { "type": "string" }
            },
            "required": ["file_path", "context"]
          }
        },
        "artifact_references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_type": { "type": "string" },
              "artifact_path": { "type": "string" },
              "section_referenced": { "type": ["string", "null"] }
            },
            "required": ["artifact_type", "artifact_path"]
          }
        },
        "observations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "observation_id": { "type": "string" },
              "description": { "type": "string" },
              "observer": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "context": { "type": "string" }
            },
            "required": ["observation_id", "description", "observer", "timestamp", "context"]
          }
        }
      },
      "required": ["file_references", "artifact_references", "observations"]
    },
    "scope_mismatches": {
      "type": "object",
      "properties": {
        "spec_vs_implementation": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "spec_requirement": { "type": "string" },
              "implementation_status": { "type": "string", "enum": ["implemented", "partially_implemented", "not_implemented", "exceeded_spec"] },
              "details": { "type": "string" }
            },
            "required": ["spec_requirement", "implementation_status", "details"]
          }
        },
        "unauthorized_additions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "addition_description": { "type": "string" },
              "location": { "type": "string" },
              "justification": { "type": ["string", "null"] },
              "recommendation": { "type": "string", "enum": ["accept", "reject", "document_and_accept"] }
            },
            "required": ["addition_description", "location", "recommendation"]
          }
        },
        "scope_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gap_description": { "type": "string" },
              "spec_reference": { "type": "string" },
              "impact": { "type": "string" }
            },
            "required": ["gap_description", "spec_reference", "impact"]
          }
        }
      },
      "required": ["spec_vs_implementation", "unauthorized_additions", "scope_gaps"]
    },
    "quality_concerns": {
      "type": "object",
      "properties": {
        "maintainability": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concern_id": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": "string" },
              "severity": { "type": "string", "enum": ["major", "minor"] },
              "suggestion": { "type": "string" }
            },
            "required": ["concern_id", "description", "location", "severity", "suggestion"]
          }
        },
        "performance": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concern_id": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": ["string", "null"] },
              "severity": { "type": "string", "enum": ["major", "minor"] },
              "suggestion": { "type": ["string", "null"] }
            },
            "required": ["concern_id", "description", "severity"]
          }
        },
        "security_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concern_id": { "type": "string" },
              "description": { "type": "string" },
              "location": { "type": "string" },
              "severity": { "type": "string", "enum": ["major", "minor"] },
              "recommendation": { "type": "string" }
            },
            "required": ["concern_id", "description", "location", "severity", "recommendation"]
          }
        },
        "other_concerns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concern_id": { "type": "string" },
              "category": { "type": "string" },
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["major", "minor"] }
            },
            "required": ["concern_id", "category", "description", "severity"]
          }
        }
      },
      "required": ["maintainability", "performance", "security_flags", "other_concerns"]
    },
    "governance_alignment_status": {
      "type": "object",
      "properties": {
        "overall_status": { "type": "string", "enum": ["aligned", "drift_detected", "critical_drift"] },
        "alignment_details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "document_type": { "type": "string" },
              "aligned": { "type": "boolean" },
              "conflicts": { "type": ["array", "null"], "items": { "type": "string" } },
              "drift_description": { "type": ["string", "null"] }
            },
            "required": ["document_type", "aligned", "conflicts", "drift_description"]
          }
        }
      },
      "required": ["overall_status", "alignment_details"]
    },
    "governance_conflicts": {
      "type": "object",
      "properties": {
        "has_conflicts": { "type": "boolean" },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "conflict_id": { "type": "string" },
              "document_1": { "type": "string" },
              "document_2": { "type": "string" },
              "conflict_description": { "type": "string" },
              "severity": { "type": "string", "enum": ["blocker", "major", "minor"] },
              "resolution_recommendation": { "type": "string" }
            },
            "required": ["conflict_id", "document_1", "document_2", "conflict_description", "severity", "resolution_recommendation"]
          }
        },
        "sync_required": { "type": "boolean" },
        "sync_details": { "type": ["string", "null"] }
      },
      "required": ["has_conflicts", "conflicts", "sync_required", "sync_details"]
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "question_id": { "type": "string" },
          "question": { "type": "string" },
          "context": { "type": "string" },
          "blocking": { "type": "boolean" },
          "suggested_owner": { "type": "string", "enum": ["architect", "developer", "tester", "management"] },
          "urgency": { "type": "string", "enum": ["high", "medium", "low"] }
        },
        "required": ["question_id", "question", "context", "blocking", "suggested_owner", "urgency"]
      }
    },
    "recommended_next_action": {
      "type": "object",
      "properties": {
        "action": { "type": "string", "enum": ["accept", "reject", "request_changes", "escalate"] },
        "rationale": { "type": "string" },
        "conditions_for_acceptance": { "type": ["array", "null"], "items": { "type": "string" } },
        "escalation_target": { "type": ["string", "null"] },
        "handoff_artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_type": { "type": "string" },
              "artifact_path": { "type": "string" },
              "notes": { "type": ["string", "null"] }
            },
            "required": ["artifact_type", "artifact_path"]
          }
        }
      },
      "required": ["action", "rationale", "conditions_for_acceptance", "escalation_target", "handoff_artifacts"]
    }
  },
  "required": [
    "report_id", "created_at", "created_by", "review_target",
    "reviewed_inputs", "summary_judgment", "findings_by_severity",
    "evidence_references", "scope_mismatches", "quality_concerns",
    "governance_alignment_status", "governance_conflicts",
    "open_questions", "recommended_next_action"
  ],
  "additionalProperties": false
}