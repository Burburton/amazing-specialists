  "deprecation_schedule": [],
  
  "upgrade_rules": {
    "patch": {
      "description": "Bug fixes and documentation updates",
      "auto_upgradable": true,
      "migration_required": false,
      "rollback_supported": true
    },
    "minor": {
      "description": "New features, backward compatible",
      "auto_upgradable": true,
      "migration_required": false,
      "rollback_supported": true
    },
    "major": {
      "description": "Breaking changes",
      "auto_upgradable": false,
      "migration_required": true,
      "rollback_supported": false
    }
  },
  
  "validation_rules": {
    "version_sync": {
      "description": "Package version must sync with component versions",
      "rules": [
        "Package MAJOR → Contract Pack MAJOR",
        "Package MAJOR → Template Pack MAJOR",
        "Contract Pack MAJOR → Package MAJOR"
      ]
    },
    "changelog_required": {
      "description": "Every release must have CHANGELOG entry",
      "required_sections": ["Added", "Changed", "Deprecated", "Removed", "Fixed"]
    }
  }
}