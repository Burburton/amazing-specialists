{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/pack/docs/changelog-entry.schema.json",
  "title": "Changelog Entry Contract",
  "description": "Structured changelog entry with change type classification, capability changes, and breaking changes notes",
  "type": "object",
  "properties": {
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "feature_id": { "type": "string" },
    "feature_name": { "type": "string" },
    "change_type": { "type": "string", "enum": ["feature", "repair", "docs-only", "governance"] },
    "summary": { "type": "string", "minLength": 50, "maxLength": 150 },
    "capability_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "user_impact": { "type": "string" },
          "breaking": { "type": "boolean" }
        },
        "required": ["description", "user_impact", "breaking"]
      }
    },
    "docs_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "document": { "type": "string" },
          "change_description": { "type": "string" },
          "user_impact": { "type": "string" }
        },
        "required": ["document", "change_description", "user_impact"]
      }
    },
    "validation_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "scope": { "type": "string" },
          "impact": { "type": "string" }
        },
        "required": ["description", "scope", "impact"]
      }
    },
    "breaking_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "change": { "type": "string" },
          "affected_usage": { "type": "string" },
          "migration_path": { "type": "string" },
          "severity": { "type": "string", "enum": ["major", "minor"] },
          "announced_deprecation": { "type": "boolean" }
        },
        "required": ["change", "affected_usage", "migration_path", "severity", "announced_deprecation"]
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "limitation": { "type": "string" },
          "impact": { "type": "string" },
          "workaround": { "type": ["string", "null"] },
          "planned_resolution": { "type": ["string", "null"] }
        },
        "required": ["limitation", "impact", "workaround", "planned_resolution"]
      }
    },
    "related_features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "feature_id": { "type": "string" },
          "relationship": { "type": "string", "enum": ["depends-on", "enables", "supersedes", "related"] },
          "description": { "type": "string" }
        },
        "required": ["feature_id", "relationship", "description"]
      }
    }
  },
  "required": [
    "created_at", "created_by", "feature_id", "feature_name",
    "change_type", "summary", "capability_changes",
    "docs_changes", "validation_changes", "breaking_changes",
    "known_limitations", "related_features"
  ],
  "additionalProperties": false
}