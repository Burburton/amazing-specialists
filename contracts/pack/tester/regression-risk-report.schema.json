{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/pack/tester/regression-risk-report.schema.json",
  "title": "Regression Risk Report Contract",
  "description": "Analysis of regression risks from code changes with recommended regression test scope",
  "type": "object",
  "properties": {
    "dispatch_id": { "type": "string" },
    "task_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "change_anchor": {
      "type": "object",
      "properties": {
        "change_type": { "type": "string", "enum": ["feature", "bugfix", "refactor", "config"] },
        "change_summary": { "type": "string" },
        "changed_files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "change_summary": { "type": "string" }
            },
            "required": ["path", "change_summary"]
          }
        },
        "related_bugfix_report": { "type": ["string", "null"] }
      },
      "required": ["change_type", "change_summary", "changed_files", "related_bugfix_report"]
    },
    "regression_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "surface_id": { "type": "string" },
          "module": { "type": "string" },
          "functionality": { "type": "string" },
          "connection_type": { "type": "string", "enum": ["direct", "indirect", "shared_dependency", "data_flow"] },
          "connection_description": { "type": "string" },
          "likelihood": { "type": "string", "enum": ["high", "medium", "low"] },
          "impact_severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "risk_score": { "type": "number", "minimum": 1, "maximum": 10 }
        },
        "required": ["surface_id", "module", "functionality", "connection_type", "connection_description", "likelihood", "impact_severity", "risk_score"]
      }
    },
    "existing_tests_reused": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "test_id": { "type": "string" },
          "test_file": { "type": "string" },
          "test_name": { "type": "string" },
          "covers_surface": { "type": "string" },
          "execution_result": { "type": "string", "enum": ["pass", "fail", "not_run"] },
          "notes": { "type": ["string", "null"] }
        },
        "required": ["test_id", "test_file", "test_name", "covers_surface", "execution_result"]
      }
    },
    "new_regression_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "check_id": { "type": "string" },
          "description": { "type": "string" },
          "covers_surface": { "type": "string" },
          "test_file": { "type": ["string", "null"] },
          "test_type": { "type": "string", "enum": ["unit", "integration", "e2e", "manual"] },
          "rationale": { "type": "string" }
        },
        "required": ["check_id", "description", "covers_surface", "test_type", "rationale"]
      }
    },
    "untested_regression_areas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "area_id": { "type": "string" },
          "surface_id": { "type": "string" },
          "description": { "type": "string" },
          "reason_untested": { "type": "string" },
          "risk_assessment": { "type": "string" },
          "mitigation_recommendation": { "type": "string" },
          "priority_to_address": { "type": "string", "enum": ["high", "medium", "low"] }
        },
        "required": ["area_id", "surface_id", "description", "reason_untested", "risk_assessment", "mitigation_recommendation", "priority_to_address"]
      }
    },
    "risk_ranking": {
      "type": "object",
      "properties": {
        "methodology": { "type": "string" },
        "top_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "risk_id": { "type": "string" },
              "surface_id": { "type": "string" },
              "combined_score": { "type": "number" },
              "recommendation": { "type": "string" }
            },
            "required": ["risk_id", "surface_id", "combined_score", "recommendation"]
          }
        },
        "risk_matrix": {
          "type": "object",
          "properties": {
            "high_likelihood_high_impact": { "type": "array", "items": { "type": "string" } },
            "high_likelihood_low_impact": { "type": "array", "items": { "type": "string" } },
            "low_likelihood_high_impact": { "type": "array", "items": { "type": "string" } },
            "low_likelihood_low_impact": { "type": "array", "items": { "type": "string" } }
          },
          "required": ["high_likelihood_high_impact", "high_likelihood_low_impact", "low_likelihood_high_impact", "low_likelihood_low_impact"]
        }
      },
      "required": ["methodology", "top_risks", "risk_matrix"]
    },
    "follow_up_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "action_id": { "type": "string" },
          "action_type": { "type": "string", "enum": ["create_test", "update_test", "monitor", "document", "escalate"] },
          "description": { "type": "string" },
          "owner": { "type": "string" },
          "deadline": { "type": ["string", "null"] },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "blocked"] }
        },
        "required": ["action_id", "action_type", "description", "owner", "priority", "status"]
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["ACCEPT_RISK", "REWORK", "ESCALATE"]
    },
    "historical_context": {
      "type": "object",
      "properties": {
        "similar_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "change_id": { "type": "string" },
              "description": { "type": "string" },
              "regressions_introduced": {
                "type": "array",
                "items": { "type": "string" }
              },
              "lessons_learned": { "type": "string" }
            }
          }
        },
        "related_bug_history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "bug_id": { "type": "string" },
              "description": { "type": "string" },
              "root_cause": { "type": "string" },
              "fix_verified": { "type": "boolean" }
            }
          }
        }
      }
    },
    "regression_coverage_percentage": { "type": "number" },
    "estimated_risk_exposure": { "type": "string" }
  },
  "required": [
    "dispatch_id", "task_id", "created_at", "created_by",
    "change_anchor", "regression_surfaces", "existing_tests_reused",
    "new_regression_checks", "untested_regression_areas",
    "risk_ranking", "follow_up_actions", "recommendation"
  ],
  "additionalProperties": false
}