          "full": {
            "file_count": 190,
            "skill_count": 37,
            "compatible_with_package": ["1.0.0"]
          }
        },
        "breaking_changes": [],
        "new_features": [
          "Minimal profile (21 MVP skills)",
          "Full profile (37 skills with M4)",
          "CLI tools (init/install/doctor)",
          "Documentation (USAGE.md, PROFILE-COMPARISON.md, UPGRADE-STRATEGY.md)"
        ]
      }
    },
    
    "tooling": {
