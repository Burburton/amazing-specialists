            "version": "1.0.0",
            "supported_flags": ["--profile", "--force"],
            "supported_profiles": ["minimal", "full"]
          },
          "install.js": {
            "version": "1.0.0",
            "supported_flags": ["--profile", "--upgrade", "--dry-run"]
          },
          "doctor.js": {
            "version": "1.0.0",
            "supported_flags": ["--verbose", "--fix"],
            "check_count": 10
          }
        }
      }
    },
    
    "adapters": {
