{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/pack/reviewer/acceptance-decision-record.schema.json",
  "title": "Acceptance Decision Record Contract",
  "description": "Formal record of acceptance decision with conditions, evidence, and traceability to upstream artifacts",
  "type": "object",
  "properties": {
    "dispatch_id": { "type": "string" },
    "task_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string" },
    "target_feature": {
      "type": "object",
      "properties": {
        "feature_id": { "type": "string" },
        "feature_name": { "type": "string" },
        "deliverable_type": { "type": "string", "enum": ["feature", "bugfix", "enhancement", "refactor"] },
        "review_scope": { "type": "string" }
      },
      "required": ["feature_id", "feature_name", "deliverable_type", "review_scope"]
    },
    "decision_state": {
      "type": "string",
      "enum": ["accept", "accept-with-conditions", "reject", "needs-clarification"]
    },
    "decision_timestamp": { "type": "string", "format": "date-time" },
    "decision_rationale": {
      "type": "object",
      "properties": {
        "summary": { "type": "string", "minLength": 50 },
        "key_factors": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence_summary": { "type": "string" },
        "alternative_states_considered": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "state": { "type": "string" },
              "reason_rejected": { "type": "string" }
            },
            "required": ["state", "reason_rejected"]
          }
        }
      },
      "required": ["summary", "key_factors", "evidence_summary", "alternative_states_considered"]
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["blocker", "major", "minor", "note"] },
          "category": { "type": "string", "enum": ["correctness", "completeness", "consistency", "security", "performance", "governance"] },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "impact": { "type": "string" },
          "remediation_required": { "type": "string" },
          "evidence_reference": { "type": "string" }
        },
        "required": ["issue_id", "severity", "category", "description", "location", "impact", "remediation_required", "evidence_reference"]
      }
    },
    "non_blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "issue_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["minor", "note"] },
          "category": { "type": "string", "enum": ["maintainability", "style", "documentation", "optimization"] },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "recommendation": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] }
        },
        "required": ["issue_id", "severity", "category", "description", "location", "recommendation", "priority"]
      }
    },
    "acceptance_conditions": {
      "type": "object",
      "properties": {
        "conditions_present": { "type": "boolean" },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition_id": { "type": "string" },
              "description": { "type": "string" },
              "responsible_role": { "type": "string", "enum": ["developer", "tester", "docs", "security"] },
              "due_within": { "type": ["string", "null"] },
              "verification_method": { "type": "string" }
            },
            "required": ["condition_id", "description", "responsible_role", "due_within", "verification_method"]
          }
        },
        "residual_risks": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["conditions_present", "conditions", "residual_risks"]
    },
    "downstream_recommendation": {
      "type": "object",
      "properties": {
        "primary_action": {
          "type": "string",
          "enum": ["PROCEED_TO_ACCEPTANCE", "RETURN_TO_DEVELOPER", "REQUEST_CLARIFICATION", "ESCALATE"]
        },
        "target_roles": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "urgency": { "type": "string", "enum": ["normal", "high", "urgent"] },
        "handoff_artifacts": { "type": "array", "items": { "type": "string" } },
        "next_steps": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["primary_action", "target_roles", "urgency", "handoff_artifacts", "next_steps"]
    },
    "reviewer_confidence_level": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
        "justification": { "type": "string" },
        "evidence_quality": { "type": "string" },
        "assumptions_made": { "type": "array", "items": { "type": "string" } },
        "gaps_in_evidence": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["level", "justification", "evidence_quality", "assumptions_made", "gaps_in_evidence"]
    },
    "governance_compliance": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["COMPLIANT", "PARTIAL_COMPLIANCE", "NON_COMPLIANT"] },
        "canonical_documents_checked": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "document": { "type": "string" },
              "aligned": { "type": "boolean" },
              "conflicts": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["document", "aligned", "conflicts"]
          }
        },
        "governance_conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "conflict_id": { "type": "string" },
              "document": { "type": "string" },
              "section": { "type": "string" },
              "description": { "type": "string" },
              "severity": { "type": "string", "enum": ["major", "blocker"] },
              "remediation": { "type": "string" }
            },
            "required": ["conflict_id", "document", "section", "description", "severity", "remediation"]
          }
        },
        "status_truthfulness": {
          "type": "object",
          "properties": {
            "completion_report_status": { "type": "string" },
            "readme_status": { "type": "string" },
            "aligned": { "type": "boolean" },
            "discrepancy_description": { "type": ["string", "null"] }
          },
          "required": ["completion_report_status", "readme_status", "aligned", "discrepancy_description"]
        }
      },
      "required": ["status", "canonical_documents_checked", "governance_conflicts", "status_truthfulness"]
    },
    "review_context": {
      "type": "object",
      "properties": {
        "upstream_artifacts_consumed": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_type": { "type": "string" },
              "artifact_path": { "type": "string" },
              "consumed_fully": { "type": "boolean" }
            },
            "required": ["artifact_type", "artifact_path", "consumed_fully"]
          }
        },
        "review_duration_minutes": { "type": "integer" },
        "reviewer_notes": { "type": ["string", "null"] }
      }
    }
  },
  "required": [
    "dispatch_id", "task_id", "created_at", "created_by",
    "target_feature", "decision_state", "decision_timestamp",
    "decision_rationale", "blocking_issues", "non_blocking_issues",
    "acceptance_conditions", "downstream_recommendation",
    "reviewer_confidence_level", "governance_compliance"
  ],
  "additionalProperties": false
}