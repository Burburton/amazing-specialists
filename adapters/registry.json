{
  "$schema": "http://json-schema.org/draft-2020-12/schema#",
  "title": "OpenCode Expert Package Adapter Registry",
  "description": "Registry of all adapters for programmatic discovery",
  
  "registry_version": "1.0.0",
  "last_updated": "2026-03-28",
  
  "adapters": {
    "orchestrator": [
      {
        "adapter_id": "cli-local",
        "adapter_type": "orchestrator",
        "priority": "must-have",
        "status": "implemented",
        "version": "1.0.0",
        "path": "adapters/cli-local/",
        "config_file": "cli-local.config.json",
        "interface": "OrchestratorAdapter",
        "compatible_profiles": ["minimal", "full"],
        "compatible_workspaces": ["local-repo"],
        "description": "CLI/Local command-line adapter for local development workflow",
        "dispatch_mapping": {
          "input_format": "CLI arguments (process.argv)",
          "output_format": "Dispatch Payload (io-contract.md §1)",
          "mapping_doc": "ADAPTERS.md §Orchestrator Adapter §CLI/Local"
        },
        "escalation_mapping": {
          "channel": "console",
          "interactive": true
        },
        "retry_config": {
          "strategy": "interactive",
          "max_retry": 2,
          "trigger": "user_decision"
        }
      },
      {
        "adapter_id": "github-issue",
        "adapter_type": "orchestrator",
        "priority": "later",
        "status": "implemented",
        "version": "1.0.0",
        "path": "adapters/github-issue/",
        "config_file": "github-issue.config.json",
        "interface": "OrchestratorAdapter",
        "compatible_profiles": ["minimal", "full"],
        "compatible_workspaces": ["github-pr", "local-repo"],
        "description": "GitHub Issue orchestrator adapter - receives tasks via GitHub Issues",
        "dispatch_mapping": {
          "input_format": "GitHub Issue (number, body, labels)",
          "output_format": "Dispatch Payload (io-contract.md §1)",
          "mapping_doc": "adapters/github-issue/README.md"
        },
        "escalation_mapping": {
          "channel": "github_comment",
          "label_trigger": "escalation:needs-decision"
        },
        "retry_config": {
          "strategy": "auto",
          "max_retry": 1,
          "trigger": "bot"
        },
        "components": {
          "issue_parser": "issue-parser.js",
          "label_parser": "label-parser.js",
          "body_parser": "body-parser.js",
          "github_client": "github-client.js",
          "webhook_handler": "webhook-handler.js",
          "comment_templates": "comment-templates.js",
          "retry_handler": "retry-handler.js"
        }
      },
      {
        "adapter_id": "openclaw",
        "adapter_type": "orchestrator",
        "priority": "later",
        "status": "design-only",
        "design_doc": "docs/adapters/openclaw-adapter-design.md",
        "interface": "OrchestratorAdapter",
        "compatible_profiles": ["minimal", "full"],
        "compatible_workspaces": ["github-pr", "local-repo", "external-system"],
        "description": "OpenClaw manager adapter (design only)",
        "dispatch_mapping": {
          "input_format": "OpenClaw dispatch message",
          "output_format": "Dispatch Payload (io-contract.md §1)",
          "mapping_doc": "docs/adapters/openclaw-adapter-design.md"
        },
        "escalation_mapping": {
          "channel": "api_callback",
          "requires_acknowledgment": true
        },
        "retry_config": {
          "strategy": "auto",
          "max_retry": 2,
          "trigger": "openclaw_policy",
          "configurable": true
        }
      }
    ],
    "workspace": [
      {
        "adapter_id": "local-repo",
        "adapter_type": "workspace",
        "priority": "must-have",
        "status": "implemented",
        "version": "1.0.0",
        "path": "adapters/local-repo/",
        "config_file": "local-repo.config.json",
        "interface": "WorkspaceAdapter",
        "compatible_profiles": ["minimal", "full"],
        "workspace_type": "local_repo",
        "description": "Local filesystem workspace adapter for file output",
        "artifact_mapping": {
          "input_format": "Execution Result (io-contract.md §2)",
          "output_format": "Local filesystem files",
          "mapping_doc": "ADAPTERS.md §Workspace Adapter §Local Repo"
        },
        "escalation_mapping": {
          "channel": "console",
          "interactive": true
        },
        "retry_config": {
          "strategy": "interactive",
          "max_retry": 2,
          "trigger": "user_decision"
        },
        "validation_rules": {
          "path_exists": true,
          "no_conflict": true,
          "profile_match": true
        }
      },
      {
        "adapter_id": "github-pr",
        "adapter_type": "workspace",
        "priority": "later",
        "status": "design-only",
        "design_doc": "docs/adapters/github-pr-adapter-design.md",
        "interface": "WorkspaceAdapter",
        "compatible_profiles": ["minimal", "full"],
        "workspace_type": "github_repo",
        "description": "GitHub PR workspace adapter (design only)",
        "artifact_mapping": {
          "input_format": "Execution Result (io-contract.md §2)",
          "output_format": "GitHub PR (files, commits)",
          "mapping_doc": "docs/adapters/github-pr-adapter-design.md"
        },
        "escalation_mapping": {
          "channel": "github_comment",
          "review_status": true
        },
        "retry_config": {
          "strategy": "configurable",
          "max_retry": 2,
          "trigger": "user_decision"
        }
      },
      {
        "adapter_id": "external-system",
        "adapter_type": "workspace",
        "priority": "future",
        "status": "design-only",
        "design_doc": "docs/adapters/external-adapter-design.md",
        "interface": "WorkspaceAdapter",
        "compatible_profiles": ["full"],
        "workspace_type": "external_system",
        "description": "External system workspace adapter (design only)",
        "artifact_mapping": {
          "input_format": "Execution Result (io-contract.md §2)",
          "output_format": "External API",
          "mapping_doc": "docs/adapters/external-adapter-design.md"
        },
        "escalation_mapping": {
          "channel": "api",
          "requires_acknowledgment": true
        },
        "retry_config": {
          "strategy": "configurable",
          "max_retry": 2,
          "trigger": "configurable"
        }
      }
    ]
  },
  
  "interfaces": {
    "OrchestratorAdapter": {
      "definition": "adapters/interfaces/orchestrator-adapter.interface.ts",
      "contract_reference": "io-contract.md §8"
    },
    "WorkspaceAdapter": {
      "definition": "adapters/interfaces/workspace-adapter.interface.ts",
      "contract_reference": "io-contract.md §8"
    }
  },
  
  "schemas": {
    "workspace_configuration": {
      "definition": "adapters/schemas/workspace-configuration.schema.json",
      "description": "JSON Schema for workspace adapter configuration"
    }
  },
  
  "shared_utilities": {
    "version_check": {
      "path": "adapters/shared/version-check.js",
      "description": "Version compatibility checker using compatibility-matrix.json"
    },
    "profile_loader": {
      "path": "adapters/shared/profile-loader.js",
      "description": "Profile configuration loader using templates/pack"
    },
    "workspace_config_validator": {
      "path": "adapters/shared/workspace-config-validator.js",
      "description": "Workspace configuration validator"
    },
    "profile_workspace_mapping": {
      "path": "adapters/shared/profile-workspace-mapping.json",
      "description": "Profile to workspace compatibility mapping"
    }
  },
  
  "rules": {
    "adapter_isolation": {
      "orchestrator_workspace": "independent",
      "boundary": "ExecutionResult",
      "single_adapter_per_execution": true
    },
    "contract_consumption": {
      "orchestrator": "io-contract.md §1",
      "workspace": "io-contract.md §2, §3",
      "validation_tool": "contracts/pack/validate-schema.js"
    },
    "version_compatibility": {
      "source": "compatibility-matrix.json",
      "incompatible_status": "BLOCKED",
      "migration_required": "hint_user"
    },
    "profile_integration": {
      "ir_001": "Profile determines skill set",
      "ir_002": "Workspace determines output format",
      "ir_003": "Profile version compatibility check",
      "ir_004": "Profile-adapter interface"
    }
  }
}